# ============================================
# EasyShop 环境变量配置示例
# 复制为 .env 并填入实际值即可使用
# ============================================

# ---- 数据库 ----
DATABASE_URL=mysql+aiomysql://root:your_password@mysql:3306/ecommerce_db
# 或使用 SQLite: sqlite+aiosqlite:///./ecommerce.db

# ---- JWT 安全（生产环境必须修改！）----
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-generate-with-secrets-token-urlsafe-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- 支付宝沙箱配置 ----
ALIPAY_APP_ID=your_app_id
ALIPAY_PRIVATE_KEY_PATH=private_key.pem
ALIPAY_PUBLIC_KEY_PATH=public_key.pem
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=http://your-domain.com/api/v1/payment/alipay/notify
ALIPAY_RETURN_URL=http://your-domain.com/payment-return
VERIFY_SIGN=False

# ---- Docker Compose ----
DB_PASSWORD=root
DB_NAME=ecommerce_db
NGROK_AUTHTOKEN=your_ngrok_token
